{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "backend/public/**"
      }
    }
  ],
  "functions": {
    "backend/server.js": {
      "excludeFiles": "backend/node_modules/onnxruntime-node/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/server.js"
    }
  ]
}
