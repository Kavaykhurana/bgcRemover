NODE_ENV=development

# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8080,http://localhost:8080

# AI Providers
AI_PROVIDER=auto              # auto | local | removebg
REMOVEBG_API_KEY=             # Required if AI_PROVIDER=removebg or auto

# File Handling
MAX_FILE_SIZE_BYTES=5242880   # 5MB
TEMP_DIR=/tmp
TEMP_FILE_TTL_MS=120000       # 2 minutes

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_UNAUTHENTICATED=10
RATE_LIMIT_MAX_AUTHENTICATED=60

# Logging
LOG_LEVEL=info
